' ── WCS UPDATE (R8 inside render loop) ──────────────────────────────────────────
group WCS rest-frequency update  <size:10>[SRP violation — R8 inside per-frame render method · lines 1232–1238]</size>
  note left of VDSR #FADBD8
    <b>[SRP] WCS service logic inside a rendering method.</b>
    _restFrequencyGHzChanged and HasWCS share
    zero fields with the shader cluster above —
    direct LCOM evidence. WCS belongs in WCSService.
  end note
  alt _restFrequencyGHzChanged && HasWCS
    VDSR -> DS : RecreateFrameSet(RestFrequencyGHz)
    activate DS
    DS --> VDSR
    deactivate DS
    VDSR -> DS : CreateAltSpecFrame()
    activate DS
    DS --> VDSR
    deactivate DS
  end
end group

deactivate VDSR

' ── ON RENDER OBJECT ────────────────────────────────────────────────────────────
Unity -> VDSR : OnRenderObject()
activate VDSR

note right of VDSR #FADBD8
  <b>[DIP + GRASP Prot. Variations]</b>
  OnRenderObject is NOT invoked by the URP render loop.
  This draw call silently does nothing in Unity 6 URP.
  Graphics.DrawProceduralNow is a legacy built-in RP API.
  Zero abstraction protects against the pipeline migration.
end note

group Mask point-cloud draw  <size:10>[lines 1276–1290 — legacy built-in RP API]</size>
  alt IsFullResolution && DisplayMask && ExistingMaskBuffer != null
    VDSR -> MMAT : SetBuffer(MaskEntries, ExistingMaskBuffer)
    VDSR -> MMAT : SetPass(0)
    VDSR -> GFX  : DrawProceduralNow(Points, bufferCount)  <size:9>[BREAKS IN URP]</size>
    activate GFX
    GFX --> VDSR
    deactivate GFX
  end
  alt IsFullResolution && DisplayMask && AddedMaskBuffer != null && count > 0
    VDSR -> MMAT : SetBuffer(MaskEntries, AddedMaskBuffer)
    VDSR -> MMAT : SetPass(0)
    VDSR -> GFX  : DrawProceduralNow(Points, AddedMaskEntryCount)  <size:9>[BREAKS IN URP]</size>
    activate GFX
    GFX --> VDSR
    deactivate GFX
  end
end group

deactivate VDSR

