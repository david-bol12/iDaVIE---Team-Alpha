' ── FOVEATION UNIFORMS (R4) ──────────────────────────────────────────────────────
VDSR -> MAT : SetFloat(FoveationStart), SetFloat(FoveationEnd)

group Foveated rendering decision  <size:10>[R4 — if(FoveatedRendering) · lines 1155–1166]</size>
  note left of VDSR #FEF5E7
    <b>[DIP] No IGazeProvider abstraction.</b>
    FoveatedRendering is a plain bool Inspector field.
    Hardware presence is not checked at runtime —
    the developer must remember to toggle it manually.
    Adding eye-tracking hardware = edit this if/else.
  end note
  alt FoveatedRendering == true
    VDSR -> MAT : SetFloat(FoveationJitter)
    VDSR -> MAT : SetInt(FoveatedStepsLow = 64)
    VDSR -> MAT : SetInt(FoveatedStepsHigh = 384)
  else FoveatedRendering == false
    VDSR -> MAT : SetInt(FoveatedStepsLow = MaxSteps)
    VDSR -> MAT : SetInt(FoveatedStepsHigh = MaxSteps)
  end
end group

' ── HIGHLIGHT / REGION UNIFORMS (R3 / R5) ────────────────────────────────────────
group Region highlight  <size:10>[R3+R5 — if(_regionOutline.Active) · lines 1168–1189]</size>
  note left of VDSR #FEF5E7
    <b>[CBO + SRP]</b> Renderer directly reads
    _regionOutline (CuboidLine) and
    _dataSet.XDim/YDim/ZDim to compute
    object-space highlight bounds inline.
    Coordinate math belongs in VolumeCameraDriver.
  end note
  alt _regionOutline.Active == true
    VDSR -> DS : XDim, YDim, ZDim  <size:9>(direct field read)</size>
    activate DS
    DS --> VDSR
    deactivate DS
    VDSR -> MAT : SetVector(HighlightMin/Max)
    VDSR -> MAT : SetFloat(HighlightSaturateFactor)
  else not active
    VDSR -> MAT : SetFloat(HighlightSaturateFactor = 1.0)
  end
end group

' ── MASK UNIFORMS (R3 + transform coupling) ─────────────────────────────────────
group Mask uniforms  <size:10>[R3 — if(_maskDataSet != null) · lines 1191–1210]</size>
  note left of VDSR #FEF5E7
    <b>[DIP + OCP]</b>
    MaskMode is an integer hash — AddhasCode() cast.
    Adding a new mask mode requires editing:
    MaskMode enum · Update() · BasicVolume.cginc · PaintMenuController.cs
    (4 files for one new behaviour — V-04 OCP violation).
    transform.localToWorldMatrix is called inline —
    domain math directly coupled to UnityEngine.Transform (V-10 DIP).
  end note
  alt _maskDataSet != null
    VDSR -> MAT  : SetInt(MaskMode, MaskMode.GetHashCode())
    VDSR -> MMAT : SetFloat(MaskVoxelSize)
    VDSR -> MMAT : SetColor(MaskVoxelColor)
    VDSR -> MMAT : SetInt(HighlightedSource)
    VDSR -> TRF  : localToWorldMatrix  <size:9>(direct Transform API call)</size>
    activate TRF
    TRF --> VDSR : Matrix4x4
    deactivate TRF
    VDSR -> VDSR : compute offsets[4] inline\n<size:9>modelMatrix.MultiplyVector(0.5f * MaskVoxelSize * ...)</size>
    VDSR -> MMAT : SetVectorArray(MaskVoxelOffsets)
    VDSR -> MMAT : SetMatrix(ModelMatrix)
  else _maskDataSet == null
    VDSR -> MAT  : SetInt(MaskMode, Disabled.GetHashCode())
  end
end group

' ── PROJECTION MODE KEYWORD (OCP violation) ──────────────────────────────────────
group Projection mode keyword  <size:10>[OCP violation O2 — if/else on enum · lines 1218–1221]</size>
  note left of VDSR #FADBD8
    <b>[OCP + DIP] Shader.EnableKeyword / DisableKeyword</b>
    are GLOBAL — deprecated in URP (Unity 6).
    URP requires per-material LocalKeyword.
    This call silently breaks when migrating pipelines.
    Binary if/else means adding MIP requires editing here.
  end note
  alt ProjectionMode == AverageIntensityProjection
    VDSR -> SHD : EnableKeyword("SHADER_AIP")  <size:9>[GLOBAL — breaks URP]</size>
    activate SHD
    SHD --> VDSR
    deactivate SHD
  else ProjectionMode == MaximumIntensityProjection
    VDSR -> SHD : DisableKeyword("SHADER_AIP")  <size:9>[GLOBAL — breaks URP]</size>
    activate SHD
    SHD --> VDSR
    deactivate SHD
  end
end group

