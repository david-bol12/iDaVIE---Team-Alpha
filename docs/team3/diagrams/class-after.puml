' ══════════════════════════════════════════════════════
'  TEST DOUBLES
' ══════════════════════════════════════════════════════
class NullRenderPipeline <<test>> {
  ' All methods are no-ops
  + AddCommandBuffer(evt, buf)   ' no-op
  + RemoveCommandBuffer(evt, buf) ' no-op
  + SetPipelineKeyword(kw, e)    ' no-op
  + DepthTextureAvailable() : false
  + Initialise()                 ' no-op
  + Dispose()                    ' no-op
  ──
  Namespace: iDaVIE.Rendering.Tests
  Not shipped in production builds
}

class NullMaskMode <<test>> {
  + Apply(material, maskTex)     ' no-op
  + ShaderKeyword : ""
  ──
  Namespace: iDaVIE.Rendering.Tests
}

class StubGazeProvider <<test>> {
  + GazeDirection  : Vector3 = (0,0,1)
  + GazeFocusPoint : Vector2 = (0.5, 0.5)
  + IsGazeAvailable : bool = true
  ──
  Fixed centred gaze for tests
  Namespace: iDaVIE.Rendering.Tests
}

