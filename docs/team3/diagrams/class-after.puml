' ══════════════════════════════════════════════════════
'  INTERFACES
' ══════════════════════════════════════════════════════
interface IRenderPipeline <<interface>> {
  + AddCommandBuffer(evt : CameraEvent, buf : CommandBuffer)
  + RemoveCommandBuffer(evt : CameraEvent, buf : CommandBuffer)
  + SetPipelineKeyword(keyword : string, enabled : bool)
  + DepthTextureAvailable() : bool
  + Initialise()
  + Dispose()
}

interface IMaskMode <<interface>> {
  + Apply(material : Material, maskTex : Texture3D)
  + ShaderKeyword : string
}

interface IGaze <<interface>> {
  + GazeDirection : Vector3
  + GazeFocusPoint : Vector2
  + IsGazeAvailable : bool
}

interface IRawVolumeData <<interface>> {
  + Width : int
  + Height : int
  + Depth : int
  + VoxelFormat : VoxelFormat
  + GetVoxelSlice(z : int) : NativeArray<short>
}

