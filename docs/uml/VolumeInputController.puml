    }

}

' ─── Interaction state machine and feature editing ────────────────────────────

package "Interaction and Feature Editing" {

    class FeatureInteractionController {
        + InteractionStateMachine : StateMachine<InteractionState, InteractionEvents>
        - _hoveredFeature : Feature
        - _editingFeature : Feature
        - _hoveredAnchor : FeatureAnchor
        - _editingAnchor : FeatureAnchor
        + HasHoverAnchor : bool
        + HasEditingAnchor : bool
        + ShowCursorInfo : bool
        - _isQuickMenu : bool
        - _selectionStopwatch : Stopwatch
        - _handInfoComponents : TextMeshPro[]
        - _coordDecimalPlaces : Vector3Int
        .. State machine setup ..
        - CreateInteractionStateMachine() : void
        - EnterPaintMode() : void
        - ExitPaintMode() : void
        - StartRegionEditing() : void
        - EndRegionEditing() : void
        - StartSelection() : void
        - EndSelection() : void
        - StartRequestQuickMenu(handIndex : int) : void
        - EndRequestQuickMenu() : void
        .. Per-frame update ..
        - UpdateInteractions() : void
        .. Feature editing ..
        + SetHoveredFeature(featureSetManager : FeatureSetManager, featureAnchor : FeatureAnchor) : void
        + ClearHoveredFeature(featureSetManager : FeatureSetManager, featureAnchor : FeatureAnchor) : void
        + AddNewSource() : void
        + StartEditSourceID() : void
        + UpdateSourceId() : void
        + AddNewLocation(fromSource : SteamVR_Input_Sources) : void
        + ToggleCursorInfoVisibility() : void
        .. HUD formatting ..
        - {static} GetFormattedCursorString(dataSetRenderer : VolumeDataSetRenderer, displayOutsideCube : bool) : string
        - {static} IsCursorOutsideCube(dataSetRenderer : VolumeDataSetRenderer) : bool
        - {static} GetSelectionString(dataSetRenderer : VolumeDataSetRenderer) : string
        - {static} FormatAngle(angleInRad : double) : string
    }

}

