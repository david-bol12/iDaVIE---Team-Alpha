@startuml VolumeInputController
title VolumeInputController — Proposed Decomposition
skinparam classAttributeIconSize 0
skinparam class {
    BackgroundColor White
    BorderColor #555555
    ArrowColor #555555
}
skinparam package {
    BackgroundColor #F5F5F5
    BorderColor #AAAAAA
}
hide empty members

' ─── Enumerations ─────────────────────────────────────────────────────────────

enum InteractionState {
    IdleSelecting
    IdlePainting
    EditingSourceId
    Creating
    Editing
    Painting
    VideoCamPosRecording
}

enum InteractionEvents {
    InteractionStarted
    InteractionEnded
    PaintModeEnabled
    PaintModeDisabled
    StartEditSource
    EndEditSource
    CancelEditSource
    StartVideoRecording
    EndVideoRecording
}

enum LocomotionState {
    Idle
    Moving
    Scaling
    EditingThresholdMin
    EditingThresholdMax
    EditingZAxis
}

' ─── SteamVR and Unity lifecycle ─────────────────────────────────────────────

package "SteamVR and Unity" {

    class VRInputWiring {
        + PrimaryHand : SteamVR_Input_Sources
        + PrimaryHandIndex : int
        - _player : Player
        - _hands : VRHand[]
        - _handTransforms : Transform[]
        - _grabGripAction : SteamVR_Action_Boolean
        - _grabPinchAction : SteamVR_Action_Boolean
        - _quickMenuAction : SteamVR_Action_Boolean
        - _vrFamily : VRFamily
        + <<event>> PushToTalkButtonPressed
        + <<event>> PushToTalkButtonReleased
        .. Unity lifecycle ..
        - OnEnable() : void
        - OnDisable() : void
        .. SteamVR action callbacks ..
        - OnGripChanged(fromAction : SteamVR_Action_Boolean, fromSource : SteamVR_Input_Sources, newState : bool) : void
        - OnPinchChanged(fromAction : SteamVR_Action_Boolean, fromSource : SteamVR_Input_Sources, newState : bool) : void
        - OnQuickMenuChanged(fromAction : SteamVR_Action_Boolean, fromSource : SteamVR_Input_Sources, newState : bool) : void
        - OnUiInteractDown(fromAction : SteamVR_Action_Boolean, fromSource : SteamVR_Input_Sources) : void
        - OnMenuUpPressed(fromAction : SteamVR_Action_Boolean, fromSource : SteamVR_Input_Sources) : void
        - OnMenuUpReleased(fromAction : SteamVR_Action_Boolean, fromSource : SteamVR_Input_Sources) : void
        - OnMenuDownPressed(fromAction : SteamVR_Action_Boolean, fromSource : SteamVR_Input_Sources) : void
        - OnMenuDownReleased(fromAction : SteamVR_Action_Boolean, fromSource : SteamVR_Input_Sources) : void
        - OnMenuLeftPressed(fromAction : SteamVR_Action_Boolean, fromSource : SteamVR_Input_Sources) : void
        - OnMenuRightPressed(fromAction : SteamVR_Action_Boolean, fromSource : SteamVR_Input_Sources) : void
        .. Haptics ..
        + VibrateController(hand : SteamVR_Input_Sources, duration : float, frequency : float, amplitude : float) : void
        - {static} DetermineVRFamily() : VRFamily
    }

}

' ─── VR locomotion ────────────────────────────────────────────────────────────

package "Locomotion" {

    class VRLocomotionController {
        + InPlaceScaling : bool
        + ScalingEnabled : bool
        + RotationAxisCutoff : float
        - _locomotionState : LocomotionState
        - _startDataSetScales : float[]
        - _currentGripPositions : Vector3[]
        - _startGripSeparation : Vector3
        - _startGripCenter : Vector3
        - _startGripForwardAxis : Vector3
        - _previousControllerHeight : float
        - _rotationYawCumulative : float
        - _rotationRollCumulative : float
        .. State transitions ..
        - StateTransitionMovingToIdle() : void
        - StateTransitionIdleToMoving() : void
        - StateTransitionMovingToScaling() : void
        - StateTransitionScalingToMoving() : void
        .. Per-frame updates ..
        - UpdateMoving() : void
        - UpdateScaling() : void
        - UpdateEditingThreshold(editingMax : bool) : void
        - UpdateEditingZAxis() : void
        - UpdateScalingText(dataSet : VolumeDataSetRenderer) : void
        .. Public control ..
        + StartThresholdEditing(editingMax : bool) : void
        + EndEditing() : void
        + StartZAxisEditing() : void
        .. Teleport ..
        + Teleport(boundsMin : Vector3, boundsMax : Vector3) : void
        + TeleportToVidRecLoc(pos : Vector3, rotEulerAngles : Vector3) : void
    }

    class VignetteFeedback {
        + VignetteFadeSpeed : float
        - _tunnellingVignetteOn : bool
        - _currentVignetteIntensity : float
        - _targetVignetteIntensity : float
        - _maxVignetteIntensity : float
        - UpdateVignette() : void
    }

}

