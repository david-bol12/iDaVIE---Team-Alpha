' ─────────────────────────────────────────
package "Unity runtime — not owned" <<Rectangle>> #EDE7F6 {

    class Application <<static, UnityEngine>> {
        +{static} event logMessageReceived(string, string, LogType)
        +{static} version: string
        +{static} dataPath: string
    }

    class UnityEngine_Debug <<static, UnityEngine>> {
