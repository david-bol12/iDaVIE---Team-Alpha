    -_imagePath: string
    -_maskPath: string
    -_sourcesPath: string
    -_hduSelectionIndex: int

    ' ── FITS metadata state ──────────────
    -_imageNAxis: double
    -_imageSize: double
    -_maskNAxis: double
    -_maskSize: double
    -_axisSize: Dictionary<double,double>
    -_maskAxisSize: Dictionary<double,double>

    ' ── Subset bounds state ──────────────
    -_subsetMin: int
    -_subsetMax_X: int
    -_subsetMax_Y: int
    -_subsetMax_Z: int
    -_subset: int[]
    -_trueBounds: int[]

    ' ── Runtime-resolved singletons ──────
    -_volumeCommandController: VolumeCommandController
    -_volumeInputController: VolumeInputController

    ' ── Coroutine handles ────────────────
    #_loadCubeCoroutine: Coroutine
    #_showLoadDialogCoroutine: Coroutine

    ' ── Scene-hierarchy UI components ────
