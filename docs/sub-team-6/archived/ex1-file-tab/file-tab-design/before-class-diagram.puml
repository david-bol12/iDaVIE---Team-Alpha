    +LoadCubeCoroutine(imagePath: string, maskPath: string, hduSelection: int): IEnumerator
    -postLoadFileFileSystem(): void
}

note bottom of CanvassDesktop
  <b>Mixed concerns in one MonoBehaviour (1 899 lines):</b>
  1. File-dialog orchestration (SFB callbacks)
  2. Native FITS metadata reads (P/Invoke via FitsReader)
  3. Subset-bounds arithmetic and validation
  4. Scene-hierarchy UI manipulation (≥25 transform.Find call-sites)
  5. Coroutine lifecycle management
  6. Post-load panel wiring (tab buttons, dropdowns)
  Violates SRP, OCP, and DIP; WMC >> 40.
end note

' ─────────────────────────────────────────
' Relationships
' ─────────────────────────────────────────

MonoBehaviour <|-- CanvassDesktop : extends

CanvassDesktop --> StandaloneFileBrowser : "BrowseImageFile()\nBrowseMaskFile()\nBrowseSourcesFile()\ncall OpenFilePanelAsync()"

CanvassDesktop --> FitsReader : "_browseImageFile()/_browseMaskFile()\ncall FitsOpenFile, FitsGetHduCount,\nFitsReadKey, FitsGetImageDims, etc.\n(direct native P/Invoke)"

CanvassDesktop --> VolumeDataSetRenderer : "LoadCubeCoroutine()\nsets FileName, MaskFileName,\nsubsetBounds, SelectedHdu"

CanvassDesktop ..> VolumeCommandController : "<<FindObjectOfType>>\nresolved in Start()"

CanvassDesktop ..> VolumeInputController : "<<FindObjectOfType>>\nresolved in Start()"

CanvassDesktop ..> HistogramHelper : "<<FindObjectOfType>>\nresolved in Start()"

CanvassDesktop --> GameObject : "postLoadFileFileSystem()\ntransform.Find(\"A/B/C/…\")\n.GetComponent<T>()\n(≥25 call-sites — see smell note)"

@enduml
