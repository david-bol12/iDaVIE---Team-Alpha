    -_subset_XMax_input: TMP_InputField
    -_subset_YMin_input: TMP_InputField
    -_subset_YMax_input: TMP_InputField
    -_subset_ZMin_input: TMP_InputField
    -_subset_ZMax_input: TMP_InputField
    -_zAxisDropdown: TMP_Dropdown
    -_minThreshold: Slider
    -_maxThreshold: Slider

    ' ── File-tab public entry points ─────
    +BrowseImageFile(): void
    +BrowseMaskFile(): void
    +BrowseSourcesFile(): void
    +LoadFileFromFileSystem(): void
    +CheckMemSpaceForCubes(imagePath: string, maskPath: string): bool
    +CheckImgMaskAxisSize(): void

    ' ── Internal file-tab helpers ────────
    -_browseImageFile(path: string): void
    -_browseMaskFile(path: string): void
    -IsLoadable(): bool
    -UpdateHeaderFromFits(fptr: IntPtr): void
    -setSubsetBounds(): void
