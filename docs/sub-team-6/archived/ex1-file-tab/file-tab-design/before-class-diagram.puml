@startuml file-tab-before
title File Tab — BEFORE refactoring\n(current state in Assets/Scripts/UI/CanvassDesktop.cs)

skinparam classAttributeIconSize 0
skinparam class {
    BackgroundColor #FFFDE7
    BorderColor #F57F17
    ArrowColor #5D4037
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F57F17
}

' ─────────────────────────────────────────
' Unity runtime boundary (external, not owned)
' ─────────────────────────────────────────
package "Unity runtime — not owned" <<Rectangle>> #EDE7F6 {

    class MonoBehaviour <<Unity>> {
        +StartCoroutine(routine: IEnumerator)
        +StopCoroutine(routine: Coroutine)
        +FindObjectOfType<T>(): T
    }

    class GameObject <<Unity>> {
        +transform: Transform
        +SetActive(value: bool)
        +GetComponent<T>(): T
        +GetComponentsInChildren<T>(): T[]
    }

    class Transform <<Unity>> {
        +Find(path: string): Transform
        +GetComponent<T>(): T
    }

}

note top of Transform
  <b>Code smell:</b> CanvassDesktop navigates
  scene hierarchy via long Find("A/B/C/...")
  chains — fragile and untestable.
end note

' ─────────────────────────────────────────
' Native plug-in wrapper (P/Invoke boundary)
' ─────────────────────────────────────────
class FitsReader <<static, P/Invoke>> #FCE4EC {
    +{static} FitsOpenFile(fptr, filename, status, readOnly): int
    +{static} FitsCloseFile(fptr, status): int
    +{static} FitsGetHduCount(fptr, hdunum, status): int
    +{static} FitsMovabsHdu(fptr, hdunum, hdutype, status): int
    +{static} FitsReadKey(fptr, datatype, keyname, value, comm, status): int
    +{static} FitsGetImageDims(fptr, dims, status): int
    +{static} FitsGetImageSize(fptr, dims, naxes, status): int
    +{static} FitsErrorMessage(status): string
}

note right of FitsReader
  All public methods are [DllImport("idavie_native")]
  — direct P/Invoke calls to the C shared library
  made from within CanvassDesktop business logic.
end note

' ─────────────────────────────────────────
' Third-party file-dialog library (SFB)
' ─────────────────────────────────────────
class StandaloneFileBrowser <<static, SFB>> #E8F5E9 {
    +{static} OpenFilePanelAsync(title, path, extensions, multiSelect, callback): void
}

note right of StandaloneFileBrowser
  SFB = UnityStandaloneFileBrowser,
  a third-party OS file-dialog wrapper.
  Callbacks are async; result is a string[].
end note

