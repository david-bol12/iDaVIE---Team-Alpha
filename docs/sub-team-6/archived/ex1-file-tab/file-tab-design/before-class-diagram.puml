' ─────────────────────────────────────────
' God class — File Tab responsibilities
' ─────────────────────────────────────────
class CanvassDesktop <<MonoBehaviour>> #FFCCBC {
    ' ── Inspector-wired GameObjects ──────
    +informationPanelContent: GameObject
    +renderingPanelContent: GameObject
    +mainCanvassDesktop: GameObject
    +fileLoadCanvassDesktop: GameObject
